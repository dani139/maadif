<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.maadif</groupId>
    <artifactId>maadif-analyzer</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>MAADIF APK Analyzer</name>
    <description>Mobile &amp; Application Analysis using Ghidra and JADX APIs</description>

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <jadx.version>1.5.1</jadx.version>
    </properties>

    <repositories>
        <!-- JitPack for JADX -->
        <repository>
            <id>jitpack.io</id>
            <url>https://jitpack.io</url>
        </repository>
    </repositories>

    <dependencies>
        <!-- JADX Core -->
        <dependency>
            <groupId>com.github.skylot.jadx</groupId>
            <artifactId>jadx-core</artifactId>
            <version>v${jadx.version}</version>
        </dependency>

        <!-- JADX CLI (for additional utilities) -->
        <dependency>
            <groupId>com.github.skylot.jadx</groupId>
            <artifactId>jadx-cli</artifactId>
            <version>v${jadx.version}</version>
        </dependency>

        <!-- JADX Input DEX -->
        <dependency>
            <groupId>com.github.skylot.jadx</groupId>
            <artifactId>jadx-input-api</artifactId>
            <version>v${jadx.version}</version>
        </dependency>

        <!-- JADX DEX Input -->
        <dependency>
            <groupId>com.github.skylot.jadx</groupId>
            <artifactId>jadx-dex-input</artifactId>
            <version>v${jadx.version}</version>
        </dependency>

        <!-- JADX Java Input -->
        <dependency>
            <groupId>com.github.skylot.jadx</groupId>
            <artifactId>jadx-java-input</artifactId>
            <version>v${jadx.version}</version>
        </dependency>

        <!-- JADX SMALI Input -->
        <dependency>
            <groupId>com.github.skylot.jadx</groupId>
            <artifactId>jadx-smali-input</artifactId>
            <version>v${jadx.version}</version>
        </dependency>

        <!-- Gson for JSON handling -->
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>2.10.1</version>
        </dependency>

        <!-- SLF4J for logging -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>2.0.9</version>
        </dependency>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-simple</artifactId>
            <version>2.0.9</version>
        </dependency>

        <!-- Ghidra dependencies will be loaded from local installation -->
        <!-- These are provided at runtime from /opt/ghidra -->
    </dependencies>

    <build>
        <plugins>
            <!-- Compiler plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <compilerArgs>
                        <arg>--add-exports</arg>
                        <arg>java.base/sun.security.x509=ALL-UNNAMED</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- JAR plugin with manifest -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.3.0</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>io.maadif.analyzer.ApkAnalyzer</mainClass>
                            <addClasspath>true</addClasspath>
                            <classpathPrefix>lib/</classpathPrefix>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>

            <!-- Shade plugin for fat JAR -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.1</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>io.maadif.analyzer.ApkAnalyzer</mainClass>
                                </transformer>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Profile for building with local Ghidra installation -->
        <profile>
            <id>with-ghidra</id>
            <activation>
                <property>
                    <name>ghidra.home</name>
                </property>
            </activation>
            <dependencies>
                <!-- Add Ghidra JARs from installation -->
                <dependency>
                    <groupId>ghidra</groupId>
                    <artifactId>ghidra-framework</artifactId>
                    <version>12.0</version>
                    <scope>system</scope>
                    <systemPath>${ghidra.home}/Ghidra/Framework/Generic/lib/Generic.jar</systemPath>
                </dependency>
            </dependencies>
        </profile>
    </profiles>
</project>
